<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Cucumber Test Suite"
       data-provider-thread-count="2"
       verbose="1">

    <listeners>
        <listener class-name="io.github.jeihunn.retry.testng.RetryAnnotationTransformer"/>
    </listeners>

    <test name="Cucumber Scenarios">
        <classes>
            <class name="io.github.jeihunn.runners.CucumberTestNGRunner"/>
        </classes>
    </test>

</suite>
